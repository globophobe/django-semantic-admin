{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": [
      "semantic_admin/static/import_export/*.js",
      "semantic_admin/static/semantic_admin/**/*.js"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "rules": {
      "complexity": {
        "useArrowFunction": "off",
        "useOptionalChain": "off"
      },
      "correctness": {
        "noUnusedVariables": "off"
      },
      "style": {
        "useTemplate": "off"
      },
      "suspicious": {
        "noRedundantUseStrict": "off"
      }
    }
  }
}
